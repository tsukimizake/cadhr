% mechanism: 平歯車 (spur gear) の機構記述
%
% NOTE: この .cadhr は cadhr-lang/tests/mechanism_integration.rs に include_str!
%   され、テスト走行時に db_src 先頭に連結される。ライブラリとして配布する目的
%   ではなく、translate API (点ベース) と connecting-rod 系制約のテストフィクスチャ。
%
% 部品レコード:
%   gp(Name, Module, Teeth, X, Y, Theta, Thickness)
%     - Name      : 部品名 (アトム or 文字列)
%     - Module    : 歯車モジュール (M)
%     - Teeth     : 歯数 (Z)
%     - X, Y      : 中心座標 (XY 平面)
%     - Theta     : 回転角 (degree)
%     - Thickness : 軸方向の厚み
%
% 使い方:
%   main(T1, OUT) :- do_mech([
%       gp(g1, 1, 20, 0,  0, T1, 5),
%       gp(g2, 1, 40, 30, 0, T2,    5),
%       gp(g3, 1, 20, 60, 0, T3,    5)
%   ], OUT).
%
% NOTE on tooth counts:
%   cadhr-lang は Rational ベースの線形ソルバを使うので、隣接ペアの歯数比による
%   T 計算は割り切れなくても厳密に解ける (Rational のまま伝播)。
%
% リスト要素として埋め込まれた T1, T2, T3 は同じ節のスコープに居るため、
% 内部の mesh/2 制約で束縛が伝播し、render_part でその値が描画に反映される。

% ─────── 歯車の描画 ───────
% 歯車本体はピッチ円半径の円柱で代用する (歯形は今のところ非表示)。
% 隣接歯車同士は規格通りに配置されればちょうど接触する。
%
% translate(Shape, SrcPoint, DstPoint): 歯車中心 (ローカル原点 = p(0,0,0)) を
% ワールド上の (X, Y, 0) に運ぶ。
render_part(gp(_, M, Z, X, Y, T, Th), MODEL) :-
    R = M*Z/2,
    MODEL = cylinder(R, Th)
        |> rotate(0, 0, T)
        |> translate(p(0, 0, 0), p(X, Y, 0)).

% ─────── 噛み合い制約 ───────
% 隣接する 2 つの平歯車の噛み合いを表現する。
%
% 1. モジュール一致: head パターンの同じ M で構造的に強制
%    (不一致なら unify 失敗で no-clause-matches となる)
% 2. 中心距離整合: (X2-X1)^2 + (Y2-Y1)^2 = (M*(Z1+Z2)/2)^2
%    (sqrt が無いため二乗形式)
%    位置 (X,Y) はユーザが直接書く想定で、不整合は assert_eq でラベル付きエラー
% 3. 回転比: Z1*T1 + Z2*T2 = 0
%    (外接歯車では歯数比に反比例し、回転は逆向き)
%    この式は通常 T1 が既知で T2 を解く形になるため `=` で線形ソルバに渡す。
mesh(gp(_, M, Z1, X1, Y1, T1, _), gp(_, M, Z2, X2, Y2, T2, _)) :-
    DX = X2 - X1,
    DY = Y2 - Y1,
    R = M*(Z1 + Z2)/2,
    assert_eq(DX*DX + DY*DY, R*R, "gear center distance"),
    Z1*T1 + Z2*T2 = 0.

% ─────── トラバーサル ───────
% 部品リストを 1 本の chain として扱い、隣接ペアごとに mesh/2 を適用、
% 同時に各部品を描画する。出力は描画モデルのリスト。
do_mech([G], [M]) :- render_part(G, M).
do_mech([A, B | Rest], [M | Ms]) :-
    mesh(A, B),
    render_part(A, M),
    do_mech([B | Rest], Ms).
