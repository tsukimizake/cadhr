-- loki_home_key を新 cadhr-lang で書き直し。
-- 3 平面 (XY / YZ / XZ) で別々に外周ポリゴンを描き、それぞれ extrude して
-- 3-way intersect。最後に m3 ボルト穴を 1 つ抜く。

import Bolts

xy x_outer y_outer =
    let
        hole_y_from_outer = 9.0
        hole_x_from_l = 13.0
        profile = polygon [ p2 0.0 0.0, p2 x_outer 0.0, p2 x_outer y_outer, p2 0.0 y_outer ]
        p0 = p2 (x_outer - hole_x_from_l) (y_outer - hole_y_from_outer)
    in
    { sketch = profile, p0 = p0 }

yz y_outer z_outer =
    polygon [ p2 0.0 0.0, p2 y_outer 0.0, p2 y_outer z_outer, p2 0.0 z_outer ]

xz x_outer z_outer =
    let
        top_z = 7.0
        hook_l = 13.0
        hook_len = 4.0
        hook_width = 3.0
        low_w = 12.0
        low_h = 2.0
        hook_r = hook_l + hook_width
        pts = [ p2 2.0 0.0, p2 x_outer 0.0, p2 x_outer top_z, p2 hook_r top_z, p2 hook_r z_outer, p2 hook_l z_outer, p2 (hook_l - hook_len) z_outer, p2 (hook_l - hook_len) (z_outer - hook_width), p2 hook_l (z_outer - hook_width), p2 hook_l top_z, p2 low_w low_h, p2 2.0 low_h ]
    in
    polygon pts

main =
    let
        hole_y_from_outer = 9.0
        hole_x_from_l = 13.0
        x_outer = 80.0
        y_outer = 55.0
        z_outer = 15.0
        xy_rec = xy x_outer y_outer
        sxy = xy_rec.sketch
        syz = yz y_outer z_outer
        sxz = xz x_outer z_outer
        hole_x = x_outer - hole_x_from_l
        hole_y = y_outer - hole_y_from_outer
        hole = Bolts.m3_hole z_outer
            |> translate3d (p3 0.0 0.0 0.0) (p3 hole_x hole_y 0.0)
        body3 = intersect3d (intersect3d (extrude_xy z_outer sxy) (extrude_yz x_outer syz)) (extrude_xz y_outer sxz)
        shape = diff3d body3 hole
    in
    { models = [shape], bom = [], controls = [] }
